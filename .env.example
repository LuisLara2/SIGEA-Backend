# ===== APPLICATION =====
APPLICATION_NAME=sigea
SERVER_PORT=8080

# ===== DATABASE =====
DB_URL=jdbc:postgresql://localhost:5432/sigea_db
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
HIBERNATE_DDL_AUTO=update

# ===== SWAGGER/API DOCS =====
API_DOCS_PATH=/api-docs
API_UI_PATH=/swagger-ui.html

# ===== EMAIL SERVICE (JavaMailSender) =====
# Habilitar servicio de email (false en desarrollo, true en producción)
EMAIL_ENABLED=false
# Configuración del remitente
EMAIL_FROM=noreply@sigea.com
EMAIL_NOMBRE_REMITENTE=SIGEA - Sistema de Gestión

# Configuración SMTP
# Para Gmail: smtp.gmail.com:587
# Para Outlook: smtp-mail.outlook.com:587
# Para servidor propio: tu_servidor_smtp:puerto
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Credenciales SMTP (para Gmail usar App Password si tienes 2FA)
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here


