# ===== APPLICATION =====
APPLICATION_NAME=sigea
SERVER_PORT=8080

# ===== DATABASE =====
DB_URL=jdbc:postgresql://localhost:5432/sigea_db
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
HIBERNATE_DDL_AUTO=update

# ===== SWAGGER/API DOCS =====
API_DOCS_PATH=/api-docs
API_UI_PATH=/swagger-ui.html

# ===== EMAIL SERVICE (JavaMailSender con Brevo SMTP) =====
# Habilitar servicio de email (false en desarrollo, true en producción)
EMAIL_ENABLED=true
# Configuración del remitente
EMAIL_FROM=sigea@nilver.store
EMAIL_NOMBRE_REMITENTE=SIGEA - Sistema de Gestion

# ===== CREDENCIALES SMTP BREVO =====
# ⚠️ NUNCA SUBIR ESTAS CREDENCIALES A GITHUB
# Obtén tus credenciales en: https://app.brevo.com/settings/keys/smtp
SMTP_USER=your_brevo_smtp_login@example.com
SMTP_PASS=your_brevo_smtp_key_here

# ===== MEDIA STORAGE =====
MEDIA_LOCATION=./uploads


